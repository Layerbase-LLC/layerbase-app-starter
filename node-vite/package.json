{
  "name": "layerbase-app-starter-node-vite",
  "version": "0.1.0",
  "description": "Minimal todo app demonstrating the Layerbase app contract: one stateless container, a Postgres backing store, and a /health endpoint.",
  "type": "module",
  "author": "Bob Bass",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Layerbase-LLC/layerbase-app-starter-node-vite"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "tsx src/server/index.ts",
    "check": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "hono": "^4.7.0",
    "pg": "^8.16.0",
    "tsx": "^4.20.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "prettier": "^3.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  },
  "packageManager": "pnpm@10.33.0"
}
