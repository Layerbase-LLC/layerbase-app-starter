# Copy to .env for local dev:  cp .env.example .env
# On Layerbase, DATABASE_URL (and PORT/HOST) are injected by the platform.

# Local Postgres, e.g. from spindb:  spindb create todos --engine postgresql
DATABASE_URL=postgresql://user:password@localhost:5432/todos

# Optional overrides (defaults shown)
# PORT=4000
# HOST=127.0.0.1
